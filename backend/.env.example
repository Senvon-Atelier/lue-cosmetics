# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://rue:rue_dev@localhost:5432/ruecosmetics?sslmode=disable

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Shipping config (default works when running from backend/ directory)
# SHIPPING_CONFIG_PATH=seed/config/shipping_config.json

# Auth (Plan 3)
SESSION_COOKIE_NAME=rue_session
# SESSION_COOKIE_DOMAIN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
# EMAIL_ALLOWLIST=
FRONTEND_BASE_URL=http://localhost:5173

# Paystack (Plan 5)
# Get a test secret key from https://dashboard.paystack.com/#/settings/developer
# PAYSTACK_SECRET_KEY=sk_test_PLACEHOLDER
# PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=http://localhost:5173/checkout/return

# Email (Plan 5)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@rue.example.com
